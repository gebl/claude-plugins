# Task Manager Agent — environment variables
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by the agent via python-dotenv.

# Linear API token (required)
# Get yours at: https://linear.app/settings/api
TASKMANAGER_AGENT_LINEAR_TOKEN=

# Forgejo/Gitea API token (required for PR creation)
TASKMANAGER_AGENT_FORGEJO_TOKEN=

# Forgejo/Gitea base URL (required for repo creation script)
# e.g. https://forgejo.example.com
TASKMANAGER_AGENT_FORGEJO_URL=
